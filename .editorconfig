# EditorConfig helps maintain consistent coding styles across different editors
# and IDEs. See https://editorconfig.org for more info.

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false  # Preserve hard line breaks with double spaces

# XML files
[*.xml]
indent_style = space
indent_size = 2

# Desktop files
[*.desktop]
indent_style = space
indent_size = 2
